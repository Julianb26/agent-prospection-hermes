{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "curl -fsSL https://hermes-agent.nousresearch.com/install.sh | bash"
  },
  "deploy": {
    "startCommand": "/usr/local/bin/hermes gateway run",
    "restartPolicyType": "ON_FAILURE"
  }
}
